# ══════════════════════════════════════════════
# HGVDESK PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in every value
# NEVER commit .env to GitHub
# ══════════════════════════════════════════════

# ── SERVER ──
PORT=3000
NODE_ENV=production

# ── DATABASE (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hgv_platform
DB_USER=hgv_user
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_SSL=false

# ── SECURITY ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_64_CHARACTER_RANDOM_STRING

# ── ADMIN ACCOUNT (created on first run) ──
ADMIN_EMAIL=admin@hgvdesk.co.uk
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── CORS — comma-separated list of allowed origins ──
ALLOWED_ORIGINS=https://hgvdesk.co.uk,https://www.hgvdesk.co.uk

# ── PUBLIC API KEY exposed to the frontend via /config.js ──
PUBLIC_API_KEY=

# ── EMAIL (Resend) ──
RESEND_API_KEY=
FROM_EMAIL=noreply@hgvdesk.co.uk
ALERT_EMAIL=alerts@hgvdesk.co.uk

# ── DVSA / DVLA ──
DVSA_CLIENT_ID=
DVSA_CLIENT_SECRET=
DVSA_API_KEY=
DVSA_SCOPE=https://tapi.dvsa.gov.uk/.default
DVSA_TOKEN_URL=
DVLA_API_KEY_BACKUP=
