# ══════════════════════════════════════════════
# HGV PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in every value
# NEVER commit .env to GitHub
# ══════════════════════════════════════════════

# ── SERVER ──
PORT=3000
NODE_ENV=production

# ── DATABASE (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hgv_platform
DB_USER=hgv_user
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_SSL=false

# ── SECURITY ──
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_64_CHARACTER_RANDOM_STRING

# ── ADMIN ACCOUNT (created on first run) ──
ADMIN_EMAIL=admin@fleetcommand.co.uk
ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── CORS (your domain once live) ──
# ALLOWED_ORIGINS=https://fleetcommand.co.uk
ALLOWED_ORIGINS=*
